---
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../config/site";
import { url } from "../lib/url";

const first = site.author.split(" ")[0];
---

<SiteLayout title="About" description={`About ${site.author}.`}>
  <div class="page">
    <header class="page__header">
      <p class="page__eyebrow">Hi, I'm {first}.</p>
      <h1 class="page__title">About {first}</h1>
    </header>

    <div class="about-grid">
      <article class="prose prose--wide about-intro">
        <p>
          I wear a lot of hats. I'm a historian, data scientist, and NLP engineer — as well as a digital nomad, public
          speaker, and content producer. I work primarily with multilingual documents and build tools to make them
          easier to process.
        </p>
        <p>
          I'm currently the Cultural Heritage Data Scientist at Yale University, and was previously the machine learning
          postdoc at the Smithsonian Institution's Data Science Lab. I also collaborate on several ongoing projects —
          the Bitter Aloe Project, Placing the Holocaust, Personal Writes the Political, and TheirStory — building
          custom solutions for real-world problems.
        </p>
        <p>
          If you think I'd be a good fit for your work, <a href={url("/contact")}>book a consultation</a>.
        </p>
        <p class="about-links">
          <a href={url("/contact")}>Contact</a> <span aria-hidden="true">·</span>
          <a href={url("/curriculum-vitae")}>Curriculum vitae</a>
        </p>
      </article>

      <aside class="about-aside" aria-labelledby="approach">
        <h2 id="approach" class="about-aside__title">My approach</h2>
        <p class="about-aside__lede">
          I approach every problem the same way: I listen first, so I can understand. The work I enjoy most is with
          data I've never seen before — it brings new challenges and keeps things fresh. I've trained machine learning
          models to transcribe medieval manuscripts and to identify named entities in Holocaust documents across fifteen
          languages. One thing I've learned along the way: vastly different data rarely means vastly different
          solutions.
        </p>

        <div class="about-step">
          <h3 class="about-step__title">Listen &amp; understand</h3>
          <p class="about-step__body">
            I'm rarely the content expert on a project. The first phase is almost always listening — to you, and to the
            problem — so that what I build isn't just a fix, but a solution others can reproduce.
          </p>
        </div>

        <div class="about-step">
          <h3 class="about-step__title">Build it</h3>
          <p class="about-step__body">
            Once I understand the data, I get to work tailoring a custom solution. I work primarily in Python, and
            comfortably in R.
          </p>
        </div>
      </aside>
    </div>
  </div>
</SiteLayout>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: minmax(0, 1.15fr) minmax(0, 1fr);
    gap: clamp(2rem, 5vw, 4rem);
    align-items: start;
  }

  @media (max-width: 52rem) {
    .about-grid {
      grid-template-columns: 1fr;
    }
  }

  .about-intro {
    max-width: 34rem;
    font-size: 1.1rem;
    line-height: 1.7;
  }

  .about-links {
    margin-top: 1.5rem;
    color: var(--color-text-faint);
  }

  .about-aside {
    padding: 1.75rem 1.75rem 1.5rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
  }

  .about-aside__title {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    font-weight: 600;
    margin: 0.35rem 0 0.75rem;
    color: var(--color-text);
  }

  .about-aside__lede {
    margin: 0 0 1.5rem;
    font-size: 1rem;
    line-height: 1.6;
    color: var(--color-text-muted);
  }

  .about-step {
    padding-top: 1.1rem;
    margin-top: 1.1rem;
    border-top: 1px solid var(--color-border-subtle);
  }

  .about-step__num {
    font-family: var(--font-serif);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--color-accent);
    margin: 0 0 0.25rem;
  }

  .about-step__title {
    font-family: var(--font-serif);
    font-size: 1.15rem;
    font-weight: 600;
    margin: 0 0 0.35rem;
    color: var(--color-text);
  }

  .about-step__body {
    margin: 0;
    font-size: 0.98rem;
    line-height: 1.55;
    color: var(--color-text-muted);
  }
</style>
