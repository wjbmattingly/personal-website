---
import { getCollection, render, type CollectionEntry } from "astro:content";
import SiteLayout from "../components/SiteLayout.astro";
import { site } from "../config/site";
import { url } from "../lib/url";

const raw = await getCollection("projects");
const sorted = raw.sort((a, b) => a.data.order - b.data.order);

const blocks = await Promise.all(
  sorted.map(async (p: CollectionEntry<"projects">) => {
    const { Content } = await render(p);
    return { entry: p, Content };
  })
);
---

<SiteLayout
  title="Projects"
  description={`Selected projects and collaborations for ${site.author}.`}
>
  <div class="page wrap--reading">
    <header class="page__header">
      <h1 class="page__title">Projects</h1>
    </header>

    <ul class="project-list" role="list">
      {
        blocks.map(({ entry: p, Content }) => (
          <li class="project-item">
            {p.data.image ? (
              <div class="project-item__media">
                <img
                  src={url(p.data.image)}
                  alt=""
                  width={400}
                  height={280}
                  loading="lazy"
                />
              </div>
            ) : null}
            <div class="project-item__body">
              <h2 class="project-item__title">{p.data.title}</h2>
              {p.data.tagline ? <p class="project-item__tagline">{p.data.tagline}</p> : null}
              <div class="prose prose--wide project-item__prose">
                <Content />
              </div>
              {p.data.link ? (
                <p class="project-item__link">
                  <a href={p.data.link} rel="noreferrer">
                    Visit project <span aria-hidden="true">→</span>
                  </a>
                </p>
              ) : null}
            </div>
          </li>
        ))
      }
    </ul>
  </div>
</SiteLayout>

<style>
  .project-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0;
  }

  .project-item {
    display: grid;
    grid-template-columns: 11rem minmax(0, 1fr);
    gap: 1.5rem 2rem;
    align-items: start;
    padding: 2.25rem 0;
    border-top: 1px solid var(--color-border-subtle);
  }

  .project-item:last-child {
    border-bottom: 1px solid var(--color-border-subtle);
  }

  @media (max-width: 52rem) {
    .project-item {
      grid-template-columns: 1fr;
    }
    .project-item__media {
      max-width: 18rem;
    }
  }

  .project-item__media {
    border: 1px solid var(--color-border-subtle);
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--color-bg-warm);
  }

  .project-item__media img {
    width: 100%;
    height: auto;
    aspect-ratio: 4 / 3;
    object-fit: cover;
    display: block;
  }

  .project-item__title {
    font-family: var(--font-serif);
    font-size: clamp(1.45rem, 2.5vw, 1.85rem);
    font-weight: 600;
    line-height: 1.15;
    margin: 0 0 0.45rem;
    color: var(--color-text);
  }

  .project-item__tagline {
    margin: 0 0 0.85rem;
    font-size: 0.88rem;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-faint);
  }

  .project-item__prose {
    font-size: 1rem;
    line-height: 1.65;
  }

  .project-item__link {
    margin-top: 1rem;
    font-size: 0.95rem;
  }

  .project-item__link a {
    text-decoration: none;
    font-weight: 600;
    color: var(--color-ink);
  }

  .project-item__link a:hover {
    color: var(--color-accent);
  }
</style>
