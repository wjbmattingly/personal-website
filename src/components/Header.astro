---
import { site, contact, social } from "../config/site";
import { url } from "../lib/url";

const links: { href: string; label: string }[] = [
  { href: "/", label: "Home" },
  { href: "/talks", label: "Talks" },
  { href: "/projects", label: "Projects" },
  { href: "/about", label: "About" },
  { href: "/curriculum-vitae", label: "CV" },
  { href: "/blog", label: "Blog" },
];

const initials = site.author
  .split(" ")
  .map((w) => w[0])
  .join("");
---

<header class="site-header">
  <div class="wrap wrap--wide site-header__inner">
    <a href={url("/")} class="site-header__brand" aria-label={`${site.author} home`}>
      <span class="site-header__mark" aria-hidden="true">{initials}</span>
      <span class="site-header__name">{site.author}</span>
    </a>

    <ul class="site-social" aria-label="Social links" role="list">
      {
        social.map((s) => (
          <li>
            <a
              href={s.href}
              class={`site-social__link site-social__link--${s.name.toLowerCase().replace(/\s+/g, "-")}`}
              aria-label={s.name}
              rel="noreferrer"
              target="_blank"
            >
              {s.name === "GitHub" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    fill="currentColor"
                    d="M12 .5C5.37.5 0 5.87 0 12.5c0 5.3 3.44 9.8 8.21 11.39.6.11.82-.26.82-.58 0-.29-.01-1.04-.02-2.04-3.34.72-4.04-1.61-4.04-1.61-.55-1.39-1.34-1.76-1.34-1.76-1.09-.75.08-.73.08-.73 1.2.08 1.84 1.24 1.84 1.24 1.07 1.83 2.81 1.3 3.49.99.11-.78.42-1.3.76-1.6-2.66-.3-5.46-1.33-5.46-5.93 0-1.31.47-2.38 1.24-3.22-.13-.3-.54-1.53.11-3.18 0 0 1-.32 3.3 1.23a11.5 11.5 0 0 1 6 0c2.29-1.55 3.3-1.23 3.3-1.23.66 1.65.25 2.88.12 3.18.77.84 1.24 1.91 1.24 3.22 0 4.61-2.8 5.62-5.47 5.92.43.37.81 1.1.81 2.22 0 1.6-.01 2.89-.01 3.28 0 .32.22.7.83.58A12 12 0 0 0 24 12.5C24 5.87 18.63.5 12 .5Z"
                  />
                </svg>
              ) : s.name === "X" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    fill="currentColor"
                    d="M18.244 2H21.5l-7.5 8.575L22.93 22h-6.81l-5.34-6.98L4.62 22H1.36l8.02-9.168L1.07 2h6.95l4.83 6.383L18.244 2Zm-2.39 18h1.88L7.23 4H5.25l10.605 16Z"
                  />
                </svg>
              ) : s.name === "LinkedIn" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    fill="currentColor"
                    d="M20.45 20.45h-3.56v-5.57c0-1.33-.03-3.04-1.85-3.04-1.85 0-2.14 1.45-2.14 2.95v5.66H9.35V9h3.42v1.56h.05a3.75 3.75 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.13 2.06 2.06 0 0 1 0 4.13Zm1.78 13.02H3.56V9h3.56v11.45ZM22.22 0H1.77C.79 0 0 .78 0 1.73v20.54C0 23.22.79 24 1.77 24h20.45C23.2 24 24 23.22 24 22.27V1.73C24 .78 23.2 0 22.22 0Z"
                  />
                </svg>
              ) : s.name === "YouTube" ? (
                <svg viewBox="0 0 24 24" aria-hidden="true" focusable="false">
                  <path
                    fill="currentColor"
                    d="M23.5 6.2a3.02 3.02 0 0 0-2.12-2.13C19.47 3.5 12 3.5 12 3.5s-7.47 0-9.38.57A3.02 3.02 0 0 0 .5 6.2C0 8.13 0 12 0 12s0 3.87.5 5.8a3.02 3.02 0 0 0 2.12 2.13C4.53 20.5 12 20.5 12 20.5s7.47 0 9.38-.57a3.02 3.02 0 0 0 2.12-2.13C24 15.87 24 12 24 12s0-3.87-.5-5.8ZM9.6 15.6V8.4l6.24 3.6-6.24 3.6Z"
                  />
                </svg>
              ) : s.name === "Hugging Face" ? (
                <img
                  src={url("/images/icons/hf-logo.svg")}
                  alt=""
                  width="22"
                  height="22"
                  loading="lazy"
                />
              ) : null}
            </a>
          </li>
        ))
      }
    </ul>

    <nav class="main-nav" aria-label="Primary">
      {
        links.map((l) => (
          <a href={url(l.href)} class="main-nav__link">
            {l.label}
          </a>
        ))
      }
      <a href={url(contact.bookConsult.href)} class="main-nav__cta">
        {contact.bookConsult.label}
      </a>
    </nav>

    <details class="mobile-menu">
      <summary class="mobile-menu__btn" aria-label="Open menu">
        <span class="mobile-menu__bar"></span>
        <span class="mobile-menu__bar"></span>
        <span class="sr-only">Menu</span>
      </summary>
      <div class="mobile-menu__panel" role="navigation" aria-label="Mobile">
        {
          links.map((l) => (
            <a href={url(l.href)} class="mobile-menu__link">
              {l.label}
            </a>
          ))
        }
        <a href={url(contact.bookConsult.href)} class="mobile-menu__cta">
          {contact.bookConsult.label}
        </a>
      </div>
    </details>
  </div>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: color-mix(in srgb, var(--color-bg) 88%, transparent);
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    border-bottom: 1px solid var(--color-border-subtle);
  }

  .site-header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem 2rem;
    min-height: var(--header-offset);
    padding-top: 0.55rem;
    padding-bottom: 0.55rem;
  }

  .site-header__brand {
    display: inline-flex;
    align-items: center;
    gap: 0.65rem;
    text-decoration: none;
    color: var(--color-text);
    min-width: 0;
  }

  .site-header__mark {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.02em;
    color: var(--color-elevated);
    background: var(--color-ink);
    border-radius: 999px;
  }

  .site-header__name {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    font-weight: 600;
    line-height: 1;
    letter-spacing: 0;
    color: var(--color-text);
    white-space: nowrap;
  }

  .site-social {
    list-style: none;
    margin: 0 auto 0 0.5rem;
    padding: 0;
    display: flex;
    align-items: center;
    gap: 0.15rem;
  }

  .site-social__link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 2rem;
    height: 2rem;
    border-radius: 999px;
    color: var(--color-text-muted);
    transition: color 0.15s ease, background 0.15s ease, transform 0.15s ease;
  }

  .site-social__link:hover {
    color: var(--color-ink);
    background: var(--color-bg-warm);
    transform: translateY(-1px);
  }

  .site-social__link svg {
    width: 1.1rem;
    height: 1.1rem;
    display: block;
  }

  .site-social__link img {
    width: 1.35rem;
    height: 1.35rem;
    display: block;
  }

  .main-nav {
    display: flex;
    align-items: center;
    gap: 0.15rem 1.25rem;
    font-size: 0.92rem;
  }

  .main-nav__link {
    position: relative;
    padding: 0.35rem 0;
    text-decoration: none;
    color: var(--color-text-muted);
    font-weight: 500;
    transition: color 0.15s ease;
  }

  .main-nav__link::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0.1rem;
    height: 1px;
    background: var(--color-ink);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.2s ease;
  }

  .main-nav__link:hover {
    color: var(--color-text);
  }

  .main-nav__link:hover::after {
    transform: scaleX(1);
  }

  .main-nav__cta {
    margin-left: 0.5rem;
    padding: 0.45rem 0.95rem;
    font-weight: 600;
    font-size: 0.88rem;
    text-decoration: none;
    color: var(--color-elevated);
    background: var(--color-ink);
    border-radius: 999px;
    transition: background 0.15s ease;
  }

  .main-nav__cta:hover {
    color: var(--color-elevated);
    background: var(--color-link);
  }

  .mobile-menu {
    display: none;
    position: relative;
  }

  .mobile-menu summary {
    display: inline-flex;
    flex-direction: column;
    gap: 4px;
    list-style: none;
    cursor: pointer;
    padding: 0.6rem 0.7rem;
    border: 1px solid var(--color-border);
    border-radius: 999px;
    background: var(--color-elevated);
  }

  .mobile-menu summary::-webkit-details-marker {
    display: none;
  }

  .mobile-menu__bar {
    display: block;
    width: 1.1rem;
    height: 1.5px;
    background: var(--color-ink);
  }

  .mobile-menu__panel {
    position: absolute;
    right: 0;
    top: calc(100% + 0.4rem);
    min-width: 12.5rem;
    padding: 0.45rem 0.35rem;
    display: flex;
    flex-direction: column;
    gap: 0.05rem;
    background: var(--color-elevated);
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: var(--shadow-soft);
  }

  .mobile-menu__link,
  .mobile-menu__cta {
    text-decoration: none;
    color: var(--color-text);
    font-size: 0.95rem;
    padding: 0.5rem 0.7rem;
    border-radius: 2px;
  }

  .mobile-menu__link:hover,
  .mobile-menu__cta:hover {
    background: var(--color-bg-warm);
  }

  .mobile-menu__cta {
    font-weight: 600;
    color: var(--color-elevated);
    background: var(--color-ink);
    margin-top: 0.3rem;
  }

  .mobile-menu__cta:hover {
    background: var(--color-link);
    color: var(--color-elevated);
  }

  @media (max-width: 56rem) {
    .main-nav {
      display: none !important;
    }
    .site-social {
      display: none !important;
    }
    .mobile-menu {
      display: block;
    }
  }

  @media (min-width: 56.01rem) {
    .mobile-menu {
      display: none !important;
    }
  }
</style>
